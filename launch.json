 */

function doGet(e) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheets()[0]; // ใช้ Sheet ใบแรก
  const action = e.parameter.action;

  // กรณีที่ 1: บันทึกคะแนนใหม่
  if (action === "save") {
    const name = e.parameter.name || "Anonymous";
    const score = parseInt(e.parameter.score) || 0;
    const date = new Date();
    
    // บันทึกข้อมูลลงในแถวใหม่ [ชื่อ, คะแนน, วันที่]
    sheet.appendRow([name, score, date]);
  }

  // กรณีที่ 2: ดึงข้อมูลอันดับ (หรือทำหลังจากบันทึกเสร็จ)
  const rankings = getTopRankings(sheet);

  // ส่งข้อมูลกลับไปในรูปแบบ JSON
  return ContentService.createTextOutput(JSON.stringify(rankings))
    .setMimeType(ContentService.MimeType.JSON);
}

function getTopRankings(sheet) {
  const data = sheet.getDataRange().getValues();
  if (data.length <= 1) return []; // ถ้าไม่มีข้อมูล (นอกจาก Header) ให้คืนค่าอาเรย์ว่าง

  const rows = data.slice(1); // ตัดหัวตารางออก
  
  // เรียงลำดับจากคะแนนมากไปน้อย
  rows.sort((a, b) => b[1] - a[1]);

  // เลือกมาเฉพาะ 10 อันดับแรก
  const top10 = rows.slice(0, 10).map(row => ({
    name: row[0],
    score: row[1]
  }));

  return top10;
}
